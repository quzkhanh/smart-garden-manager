/**
 * Smart Garden IoT Configuration Template
 * 
 * Instructions:
 * 1. Copy this file to "config.h"
 * 2. Fill in your WiFi and Firebase credentials.
 * 3. Never commit "config.h" to GitHub if it contains real secrets!
 */

// 1. WiFi Settings
#define WIFI_SSID "Your_WiFi_Name"
#define WIFI_PASSWORD "Your_WiFi_Password"

// 2. Firebase Project Settings
// Get from Firebase Console: Project Settings > General
#define FIREBASE_API_KEY "AIzaSy..."
#define FIREBASE_URL "https://your-project-id.firebaseio.com"

// 3. User Authentication
// Create a user in Firebase Auth for your device (or use your app account)
#define USER_EMAIL "device@smartgarden.com"
#define USER_PASSWORD "password123"

// 4. Area Configuration
// Get the Area ID from the Flutter app (or look in Firestore: users/UID/areas/ID)
#define AREA_ID "YOUR_AREA_ID_HERE"
#define USER_UID "YOUR_FIREBASE_USER_UID_HERE"

// 5. Sensor Thresholds (Initial Default)
#define SOIL_MOISTURE_MIN 35
#define SOIL_MOISTURE_MAX 75
